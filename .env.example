# DeepGuard Environment Variables
# Copy to .env and fill in your values
# © 2026 TimeWealthy Limited — DeepGuard

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql://deepguard:deepguard_dev@localhost:5432/deepguard

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=your-secret-key-change-in-production

# S3-compatible storage for video files
S3_BUCKET=deepguard-uploads
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional settings
DEBUG=false
MAX_UPLOAD_MB=500
